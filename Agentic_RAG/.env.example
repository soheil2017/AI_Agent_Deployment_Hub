# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── AWS S3 ───────────────────────────────────────────────────────────────────
S3_BUCKET=my-rag-bucket

# S3 keys for the persisted FAISS index
INDEX_KEY=faiss_index/index.faiss
CHUNKS_KEY=faiss_index/chunks.pkl

# S3 prefix where raw .txt documents are stored (used by indexer.py)
DOCS_PREFIX=docs/

# ── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5            # number of chunks returned per search
CHUNK_SIZE=512     # characters per chunk
CHUNK_OVERLAP=64   # character overlap between consecutive chunks

# ── Agent ────────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o
MAX_TOOL_ROUNDS=3  # max search calls before forcing a final answer

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
