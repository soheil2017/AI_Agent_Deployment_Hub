# Copy to .env and fill in values from `sam deploy` outputs.
# Never commit .env to version control.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Bedrock Agent (from SAM outputs after deploy) ────────────────────────────
BEDROCK_AGENT_ID=<AgentId output>
BEDROCK_AGENT_ALIAS_ID=<AgentAliasId output>

# ── Knowledge Base sync (scripts/sync_kb.py) ─────────────────────────────────
BEDROCK_KB_ID=<KnowledgeBaseId output>
BEDROCK_DATA_SOURCE_ID=<DataSourceId output>

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
