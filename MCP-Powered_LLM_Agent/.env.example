# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────

# OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Tavily Search API Key (web search tool)
# Free tier available at: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Your app's public URL — used so the /api/chat route can call
# the MCP tool routes (/api/mcp/*) by absolute URL.
#
# Local development: leave as http://localhost:3000
# Vercel production:  set to your Vercel URL, e.g. https://my-agent.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
