# Copy to .env and fill in values for local development
OPENAI_API_KEY=sk-...

# S3 bucket where the FAISS index is stored
S3_BUCKET=my-rag-bucket

# S3 keys for the FAISS index and chunk list
INDEX_KEY=faiss_index/index.faiss
CHUNKS_KEY=faiss_index/chunks.pkl

# LLM and retrieval settings
LLM_MODEL=gpt-4o-mini
TOP_K=5

# Logging
LOG_LEVEL=INFO
